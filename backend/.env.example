PORT=5000
# Preferred single variable for managed DBs (optional):
# DATABASE_URL=mysql://user:password@host:port/dbname?ssl-mode=REQUIRED
DB_HOST=your-aiven-host
DB_PORT=your-aiven-port
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
JWT_ACCESS_SECRET=replace_access_secret
JWT_REFRESH_SECRET=replace_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# Comma-separated list. Supports wildcards like https://*.vercel.app
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
ALLOW_VERCEL_ORIGINS=true
COOKIE_DOMAIN=
NODE_ENV=development
