{
  "installCommand": "npm --prefix ../frontend install",
  "buildCommand": "npm --prefix ../frontend run build && rm -rf dist && cp -r ../frontend/dist ./dist",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://lms-b6ib.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

